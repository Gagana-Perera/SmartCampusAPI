# ----------------------------------------------------------------------------
# Maven Wrapper startup script for POSIX systems
# ----------------------------------------------------------------------------

# Simplified version for the student project
if [ -z "$JAVA_HOME" ]; then
  JAVACMD=java
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

# Check if mvn is in path
if command -v mvn >/dev/null 2>&1; then
  exec mvn "$@"
else
  echo "Maven not found in PATH. Please install Maven via 'brew install maven' or consult the README."
  exit 1
fi
